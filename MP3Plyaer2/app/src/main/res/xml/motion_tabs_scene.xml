    <!-- ConstraintSet for tab 0 (Like) -->
    <ConstraintSet android:id="@+id/state_tab_0">
        <Constraint android:id="@id/tab_like"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toStartOf="parent"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintBottom_toBottomOf="parent">
            <CustomAttribute
                motion:attributeName="textColor"
                motion:customColorValue="#000000" />
            <!-- selected bold -->
            <CustomAttribute
                motion:attributeName="textStyle"
                motion:customStringValue="bold" />
        </Constraint>

        <Constraint android:id="@id/tab_playlist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toEndOf="@id/tab_like"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="24dp">
            <CustomAttribute
                motion:attributeName="textColor"
                motion:customColorValue="#9E9E9E" />
            <CustomAttribute
                motion:attributeName="textStyle"
                motion:customStringValue="normal" />
        </Constraint>

        <Constraint android:id="@id/tab_songs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toEndOf="@id/tab_playlist"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="24dp">
            <CustomAttribute
                motion:attributeName="textColor"
                motion:customColorValue="#9E9E9E" />
            <CustomAttribute
                motion:attributeName="textStyle"
                motion:customStringValue="normal" />
        </Constraint>

        <Constraint android:id="@id/tab_albums"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toEndOf="@id/tab_songs"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="24dp">
            <CustomAttribute
                motion:attributeName="textColor"
                motion:customColorValue="#9E9E9E" />
            <CustomAttribute
                motion:attributeName="textStyle"
                motion:customStringValue="normal" />
        </Constraint>

        <Constraint android:id="@id/tab_artists"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            motion:layout_constraintStart_toEndOf="@id/tab_albums"
            motion:layout_constraintTop_toTopOf="parent"
            motion:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="24dp">
            <CustomAttribute
                motion:attributeName="textColor"
                motion:customColorValue="#9E9E9E" />
            <CustomAttribute
                motion:attributeName="textStyle"
                motion:customStringValue="normal" />
        </Constraint>

        <!-- Indicator under Like -->
        <Constraint android:id="@id/tab_indicator"
            android:layout_width="64dp"
            android:layout_height="3dp"
            motion:layout_constraintTop_toBottomOf="@id/tab_like"
            motion:layout_constraintStart_toStartOf="@id/tab_like"
            motion:layout_constraintEnd_toEndOf="@id/tab_like" />
    </ConstraintSet>

