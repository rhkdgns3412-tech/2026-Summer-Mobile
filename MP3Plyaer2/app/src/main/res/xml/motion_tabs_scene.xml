    <!-- Transitions between adjacent tab states (you can programmatically set transitions between states) -->
    <!-- Adjacent transitions (both directions). We declare transitions between i <-> i+1 so we can programmatically setTransition and progress during swipes. -->
    <Transition motion:constraintSetStart="@id/state_tab_0" motion:constraintSetEnd="@id/state_tab_1" motion:duration="200" />
    <Transition motion:constraintSetStart="@id/state_tab_1" motion:constraintSetEnd="@id/state_tab_2" motion:duration="200" />
    <Transition motion:constraintSetStart="@id/state_tab_2" motion:constraintSetEnd="@id/state_tab_3" motion:duration="200" />
    <Transition motion:constraintSetStart="@id/state_tab_3" motion:constraintSetEnd="@id/state_tab_4" motion:duration="200" />

    <Transition motion:constraintSetStart="@id/state_tab_1" motion:constraintSetEnd="@id/state_tab_0" motion:duration="200" />
    <Transition motion:constraintSetStart="@id/state_tab_2" motion:constraintSetEnd="@id/state_tab_1" motion:duration="200" />
    <Transition motion:constraintSetStart="@id/state_tab_3" motion:constraintSetEnd="@id/state_tab_2" motion:duration="200" />
    <Transition motion:constraintSetStart="@id/state_tab_4" motion:constraintSetEnd="@id/state_tab_3" motion:duration="200" />

