<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textBase"
        android:layout_width="150dp"

        android:layout_height="150dp"
        android:layout_centerInParent="true"
        android:background="#3348AF"
        android:gravity="center"
        android:text="Hello World!"

        android:textSize="20sp"
        android:textStyle="bold" />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="#FF0000"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="#FF0000"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="#FF0000"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="#FF0000"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:background="#FF0000"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_above="@id/textBase"
        android:layout_toStartOf="@id/textBase"

        android:background= "#00FF00"
        />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_below="@id/textBase"
        android:layout_toStartOf="@id/textBase"

        android:background= "#00FF00"
        />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_above="@id/textBase"
        android:layout_toEndOf="@id/textBase"

        android:background= "#00FF00"
        />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_below="@id/textBase"
        android:layout_toEndOf="@id/textBase"

        android:background= "#00FF00"
        />

    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignEnd="@id/textBase"
        android:layout_alignTop="@id/textBase"

        android:background="#CDDC39" />

    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignStart="@id/textBase"
        android:layout_alignBottom="@id/textBase"

        android:background="#CDDC39" />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignStart="@id/textBase"
        android:layout_alignTop="@id/textBase"

        android:background="#CDDC39" />
    <TextView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignEnd="@id/textBase"
        android:layout_alignBottom="@id/textBase"

        android:background="#CDDC39" />

</RelativeLayout>